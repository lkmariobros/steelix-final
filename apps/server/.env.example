# DATABASE_CONNECT_TIMEOUT_MS=15000
# DATABASE_SSL=false
# Default is permissive TLS (rejectUnauthorized=false) to avoid SELF_SIGNED_CERT_IN_CHAIN with some hosts/proxies.
# Set to true in production only if your CA chain is trusted by Node (or use NODE_EXTRA_CA_CERTS).
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_APPLICATION_NAME=steelix-server
