# Comma-separated frontend origins (must match where users open the portal).
# Production: https://portal.devots.com.my
CORS_ORIGIN=https://portal.devots.com.my,http://localhost:3000,http://localhost:3001
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
DATABASE_URL=
# Supabase: use Session pool URI (pooler.supabase.com:5432) from Dashboard → Connect.
# Do NOT set DATABASE_SSL=true for Supabase pooler — it breaks node-postgres and causes 15s auth timeouts.
# Pool tuning (optional):
# DATABASE_POOL_MAX=8
# DATABASE_CONNECT_TIMEOUT_MS=15000
# DATABASE_SSL=false
# Only set DATABASE_SSL=true for hosts that require an explicit Pool.ssl object (not Supabase pooler).
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_APPLICATION_NAME=steelix-server
# Supabase Storage (required for file uploads: transactions, portal Files tab, eRecruitment)
# Dashboard → Project Settings → API → Project URL + service_role key (keep secret)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: defaults to portal-files. Use profile-files if that is your bucket name.
PORTAL_FILES_BUCKET=portal-files

PORT=
RAILWAY_ENVIRONMENT=

# Kapso WhatsApp API Configuration
KAPSO_API_KEY=ed53c4b13c42c22da8e369ec6e0a8d18eec54c408ba3724806203e4cd090e885
KAPSO_API_URL=https://api.kapso.ai  # Optional, defaults to this
KAPSO_WEBHOOK_SECRET=e8ecca06d37d17aa5dfdbdf6dbfc54f0ff635aff9246122c76c8afa50e9a6b97  # Optional, for webhook verification
KAPSO_CONFIGURATION_ID=858556fa-8b9b-4810-a37c-a8cb29e3be46
KAPSO_PHONE_NUMBER_ID=934319439767856

# Feedback → Telegram (optional; required for Feedback form to send to group)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=