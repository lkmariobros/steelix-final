{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			".next",
			"dist",
			".turbo",
			"dev-dist",
			".zed",
			".vscode",
			"routeTree.gen.ts",
			"src-tauri",
			".nuxt",
			"apps/web/src/components"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useExhaustiveDependencies": "info"
			},
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"fix": "safe",
					"options": {
						"functions": ["clsx", "cva", "cn"]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"include": [
				"**/scripts/**",
				"*.js",
				"test-*.js",
				"verify-*.js",
				"update-*.js"
			],
			"linter": {
				"rules": {
					"complexity": { "noForEach": "off" },
					"suspicious": { "noExplicitAny": "off" }
				}
			}
		},
		{
			"include": ["apps/web/**"],
			"linter": {
				"rules": {
					"suspicious": { "noArrayIndexKey": "warn" },
					"a11y": {
						"useKeyWithClickEvents": "warn",
						"noLabelWithoutControl": "warn"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
